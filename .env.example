# ───── 사이트 비밀번호 (필수 — StatiCrypt 암호화) ─────
# 비워두면 사이트가 평문으로 빌드돼 종목·금액이 인터넷에 노출됨!
STATICRYPT_PASSWORD=

# ───── 데이터 수집 API (선택) ─────
# FRED https://fredaccount.stlouisfed.org/apikeys 무료 발급 (2분)
FRED_API_KEY=

# Anthropic https://console.anthropic.com 발급. 키 없으면 뉴스 감성분석 비활성
ANTHROPIC_API_KEY=

# Google Gemini API https://aistudio.google.com/apikey 무료 발급 (결제수단 불필요)
# 키 없으면 섹션별 AI 요약 자동 비활성
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# 향후 확장용 (지금은 미사용)
ALPHA_VANTAGE_KEY=
FINNHUB_KEY=
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=

# ───── 포트폴리오 입력 방식 ─────
# true: 포트폴리오 정리.xlsx 자동 파싱
# false: portfolio.csv 수동 파일 사용
USE_EXCEL_PORTFOLIO=true

# ───── 노티(향후 추가 예정) ─────
GMAIL_SENDER=
GMAIL_APP_PASSWORD=
REPORT_RECIPIENT=

# DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
